generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Location {
  id         Int         @id @default(autoincrement())
  name       String
  parentId   Int?
  parent     Location?   @relation("LocationHierarchy", fields: [parentId], references: [id])
  children   Location[]  @relation("LocationHierarchy")
  containers Container[]

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model ContainerType {
  id         Int         @id @default(autoincrement())
  name       String      @unique
  containers Container[]

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
}

model Category {
  id             Int             @id @default(autoincrement())
  name           String          @unique
  inventoryItems InventoryItem[]

  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
}

model Container {
  id              Int             @id @default(autoincrement())
  binNumber       String          @unique
  name            String
  description     String?
  notes           String?
  status          ContainerStatus @default(PARTIAL)

  locationId      Int?
  location        Location?       @relation(fields: [locationId], references: [id])

  containerTypeId Int?
  containerType   ContainerType?  @relation(fields: [containerTypeId], references: [id])

  inventoryItems  InventoryItem[]

  lastOpenedAt    DateTime?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
}

model InventoryItem {
  id                      Int           @id @default(autoincrement())
  name                    String
  inventoryType           InventoryType @default(STANDARD_ITEM)
  quantity                Int           @default(1)
  condition               String?
  notes                   String?

  manufacturer            String?
  modelNumber             String?
  serialNumber            String?
  purchaseDate            DateTime?
  purchasePrice           Float?
  warrantyEnd             DateTime?

  partNumber              String?
  replacementIntervalDays Int?
  minimumQuantity         Int?

  documentType            String?
  expirationDate          DateTime?

  containerId             Int
  container               Container     @relation(fields: [containerId], references: [id], onDelete: Cascade)

  categoryId              Int?
  category                Category?     @relation(fields: [categoryId], references: [id])

  media                   Media[]

  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
}

model Media {
  id            Int        @id @default(autoincrement())
  mediaType     MediaType  @default(PHOTO)
  fileName      String
  originalName  String
  mimeType      String
  sizeBytes     Int
  storagePath   String     @unique
  width         Int?
  height        Int?
  caption       String?
  sortOrder     Int        @default(0)

  inventoryId   Int
  inventory     InventoryItem @relation(fields: [inventoryId], references: [id], onDelete: Cascade)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([inventoryId])
  @@index([inventoryId, sortOrder])
}

enum InventoryType {
  STANDARD_ITEM
  ASSET
  CONSUMABLE
  DOCUMENT
}

enum ContainerStatus {
  EMPTY
  PARTIAL
  COMPLETE
}

enum MediaType {
  PHOTO
  RECEIPT
  MANUAL
  WARRANTY
  DOCUMENT
}